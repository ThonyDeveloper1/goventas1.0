APP_NAME="GO Systems & Technology"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Database (PostgreSQL 16) ─────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=gosystems
DB_USERNAME=postgres
DB_PASSWORD=

# ── Cache / Queue / Session (Redis 7) ────────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Octane (FrankenPHP) ───────────────────────────────────────────────────
OCTANE_SERVER=frankenphp

# ── Sanctum (SPA Auth) ────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000

# ── RENIEC (optional – leave empty to use built-in mock) ─────────────────
RENIEC_API_URL=
RENIEC_API_TOKEN=

# ── MikroTik RouterOS API (leave empty for mock mode) ────────────────────
MIKROTIK_HOST=
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=
MIKROTIK_SYNC_INTERVAL=5
MIKROTIK_CACHE_TTL=300
MIKROTIK_DEFAULT_PROFILE=default


